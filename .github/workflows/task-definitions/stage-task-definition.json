{
  "containerDefinitions": [
    {
      "name": "approval",
      "image": "033517038307.dkr.ecr.eu-north-1.amazonaws.com/approval_gate",
      "cpu": 1024,
      "memoryReservation": 1024,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp",
          "name": "approval_port",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
